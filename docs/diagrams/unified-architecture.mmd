# UNIFIED ARCHITECTURE DIAGRAM
# Bhutan EduSkill - Component + Schema + Route = 1

```mermaid
graph TB
    subgraph "FEATURE DEFINITION (1 File)"
        F[students.feature.ts]
        F --> S["Schema Definition"]
        F --> P["Permissions"]
        F --> U["UI Config"]
        F --> H["Custom Handlers"]
    end

    subgraph "GENERATED OUTPUTS"
        S --> DS["Drizzle Schema"]
        S --> TS["TypeScript Types"]

        F --> API["API Handlers"]
        F --> CMP["Components"]
        F --> HOOKS["React Hooks"]
    end

    subgraph "UNIVERSAL API ROUTE"
        API --> UA["/api/resources/[resource]/route.ts"]
        UA --> GET["GET /api/resources/students"]
        UA --> POST["POST /api/resources/students"]
        UA --> PUT["PUT /api/resources/students/:id"]
        UA --> DEL["DELETE /api/resources/students/:id"]
    end

    subgraph "UNIFIED COMPONENTS"
        CMP --> DG["FeatureDataGrid"]
        CMP --> FM["FeatureForm"]
        CMP --> LP["FeatureListPage"]
        CMP --> US["UnifiedSearch"]
    end

    subgraph "GEMINI LAYER (AI Integration)"
        GL["gemini-layer.ts"]
        GL --> SA["System Awareness"]
        GL --> AQ["Autonomous Querying"]
        GL --> SH["Self-Healing"]
    end

    subgraph "DATABASE"
        DB[(PostgreSQL)]
        GET --> DB
        POST --> DB
        PUT --> DB
        DEL --> DB
    end

    subgraph "FRONTEND"
        DG --> FE["React Pages"]
        FM --> FE
        LP --> FE
    end

    GL --> UA
    GL --> DS

    style F fill:#3b82f6
    style UA fill:#10b981
    style GL fill:#8b5cf6
    style DB fill:#f59e0b
```

```mermaid
flowchart LR
    subgraph "BEFORE: Traditional Approach"
        T1["drizzle/schema.ts"]
        T2["app/api/students/route.ts"]
        T3["components/students-grid.tsx"]
        T4["types/students.ts"]
        T1 -.-> T2
        T2 -.-> T3
        T3 -.-> T4
